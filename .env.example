# Prisma 数据库配置
# 注意：Prisma 7 使用适配器模式，DATABASE_URL 仅用于本地开发和迁移
# 生产环境通过代码中的适配器配置数据库连接

# 本地开发与迁移使用 Supabase (PostgreSQL)
DATABASE_URL="postgres://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"

# 如果使用 SQLite (Cloudflare D1) 本地开发，可改回：
# DATABASE_URL="file:./dev.db"
